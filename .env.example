# ─────────────────────────────────────────────────────────────────────────────
# BurnItDown — Claude Usage Dashboard — Environment Variables
# Copy this file to .env and fill in the values you want to override.
# All variables have sensible defaults; only set what you need to change.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend server ────────────────────────────────────────────────────────────

# Absolute path to your Claude Code data directory.
# Default: ~/.claude  (correct for most installations)
# Only override if you moved your data elsewhere or are pointing at another user's install.
# CLAUDE_DATA_PATH=/Users/yourname/.claude

# TCP port for the Express API server.
# The React dev proxy forwards /api/* to this port automatically.
# Default: 3001
# SERVER_PORT=3001

# Day-of-month when your Anthropic subscription billing period resets.
# If you subscribed on the 15th, set this to 15.
# Default: 30  (30th of every month)
# BILLING_DAY=30

# Length of Claude's rolling usage window, in hours.
# Used by the "Active usage windows" panel to estimate how much time is left
# until a session's quota window closes.
# Default: 5  (matches the /settings/usage window on Max plans)
# CLAUDE_USAGE_WINDOW_HOURS=5

# ── Frontend (React) ──────────────────────────────────────────────────────────
# Note: REACT_APP_* variables are baked into the frontend bundle at build time.

# How often the dashboard polls the API server for fresh data (seconds).
# Each poll is a "tick" — if new tokens were consumed since the previous tick,
# the tick is recorded in the Tick History section of the dashboard with its
# incremental cost. Lower = more realtime; higher = less CPU/I-O.
# Default: 90  (1 minute 30 seconds)
# REACT_APP_REFRESH_INTERVAL=90
